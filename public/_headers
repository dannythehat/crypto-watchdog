# Cache-control for Cloudflare static assets.
# Hashed build assets are immutable and can be cached forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# The SPA entry + crawl files must never be stale, so new pages/deploys
# (and new sitemap entries) show up immediately.
/
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache
/sitemap.xml
  Cache-Control: no-cache, max-age=0
/robots.txt
  Cache-Control: no-cache, max-age=0
