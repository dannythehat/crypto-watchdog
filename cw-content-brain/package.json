{
  "name": "cw-content-brain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone Phase 1 content operations toolkit for CryptoWatchdog.",
  "scripts": {
    "audit": "tsx scripts/run_phase1_audit.ts",
    "crawl": "tsx scripts/crawl_site.ts",
    "seo": "tsx scripts/score_seo.ts",
    "links": "tsx scripts/audit_links.ts",
    "internal-links": "tsx scripts/suggest_internal_links.ts",
    "draft": "tsx scripts/create_article_draft.ts",
    "update-draft": "tsx scripts/update_article_draft.ts",
    "content:snapshot": "tsx scripts/load_content_snapshot.ts",
    "content:quality": "tsx scripts/audit_content_quality.ts",
    "content:affiliates": "tsc --outDir dist && node dist/scripts/build_affiliate_placements.js",
    "content:links": "tsx scripts/audit_content_linking.ts",
    "content:audit": "tsx scripts/run_content_snapshot_audit.ts",
    "content:export": "tsx scripts/export_supabase_snapshot.ts",
    "content:confidence": "tsx scripts/summarise_audit_confidence.ts",
    "content:queue": "tsx scripts/build_priority_action_queue.ts",
    "content:metadata": "tsc --outDir dist && node dist/scripts/build_metadata_suggestions.js",
    "content:internal-links": "tsc --outDir dist && node dist/scripts/build_internal_link_placements.js",
    "content:offers": "tsc --outDir dist && node dist/scripts/build_offer_tracker.js",
    "content:gsc": "tsc --outDir dist && node dist/scripts/build_search_console_report.js",
    "content:ga4": "tsc --outDir dist && node dist/scripts/build_ga4_report.js",
    "content:seo-brain": "tsc --outDir dist && node dist/scripts/build_seo_intelligence_brain.js",
    "content:research-guard": "tsc --outDir dist && node dist/scripts/build_research_duplicate_guard.js",
    "content:agents": "tsc --outDir dist && node dist/scripts/build_agent_registry.js",
    "content:master-queue": "tsc --outDir dist && node dist/scripts/build_master_command_queue.js",
    "content:verify-rendered": "tsx scripts/verify_rendered_pages.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "playwright": "^1.49.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
